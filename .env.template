# .env.template
# This file serves as a template for the environment variables required by the application.
# Copy this file to '.env' and fill in the values appropriate for your environment.
# DO NOT commit your actual '.env' file to version control.

# --- Database Configuration ---
# DB_STRATEGY defines the type of database to use.
# Valid options might include 'sql', 'nedb', 'postgres', 'mongo' depending on implementation.
DB_STRATEGY=sql

# If using a strategy that requires connection details, uncomment and set the following:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=your_database_user
# DB_PASS=your_database_password
# DB_NAME=your_database_name

# --- Application Configuration ---
# The environment the application is running in (e.g., development, production, test)
# NODE_ENV=development

# The port the server should listen on
# PORT=3000

# API Keys and Secrets (Example)
# JWT_SECRET=your_super_secret_jwt_key
# API_KEY=your_external_api_key
